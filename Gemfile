source "https://rubygems.org"

# GitHub Pages compila el sitio automáticamente con este paquete.
# No necesitas ejecutar nada localmente para publicar.
gem "github-pages", group: :jekyll_plugins
gem "jekyll-paginate"

# Windows y JRuby: dependencias de zona horaria
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end
